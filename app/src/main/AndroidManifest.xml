<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />
    <application
        android:allowBackup="false"
        android:label="RockService Mobile"
        android:supportsRtl="true"
        android:theme="@style/Theme.RockService"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".RockchipBackupActivity"
            android:exported="false" />
        <activity
            android:name=".SuperImageExtractionActivity"
            android:exported="false" />
        <activity
            android:name=".BootImageExtractionActivity"
            android:exported="false" />
        <activity
            android:name=".DiagnosticsLogActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".HardwareValidationActivity"
            android:exported="false" />
        <activity
            android:name=".FirmwareLabActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
